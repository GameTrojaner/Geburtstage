{
  "expo": {
    "name": "Geburtstage",
    "slug": "Geburtstage",
    "version": "1.0.0-beta.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00897B"
    },
    "plugins": [
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow $(PRODUCT_NAME) to access your contacts to show birthdays."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00897B"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "BirthdayUpcoming",
              "label": "Nächste Geburtstage",
              "minWidth": "250dp",
              "minHeight": "120dp",
              "description": "Zeigt die nächsten Geburtstage (konfigurierbar)",
              "previewImage": "./assets/widget-preview.png",
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "BirthdayFavorites",
              "label": "Favoriten Geburtstage",
              "minWidth": "250dp",
              "minHeight": "120dp",
              "description": "Zeigt Geburtstage deiner Favoriten",
              "previewImage": "./assets/widget-preview.png",
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Allow Geburtstage to access your contacts to show birthdays."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#00897B",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "io.github.gametrojaner.geburtstage"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
